# Standalone asset editor — runtime config.

# Host port the editor UI is published on (http://localhost:<port>).
ASSET_EDITOR_PORT=8080

# Where the backend stores the local manifest/override cache.
# Inside the container this is the mounted volume; leave as /data for Docker.
ASSET_EDITOR_DATA_DIR=/data

# Storage is auto-connected from these on startup (no in-app connection step).
# Endpoint defaults to the MinIO on the Docker host; set creds + bucket here.
MINIO_ENDPOINT_URL=http://host.docker.internal:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=fairytale-assets
